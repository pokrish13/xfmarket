    def _find_app_icon(self, pkg_name: str, size: int = 64) -> Optional[GdkPixbuf.Pixbuf]:
        icon_theme = Gtk.IconTheme.get_default()
        search_names = [pkg_name, pkg_name.lower(), pkg_name.replace('-', '_')]
        if '.' not in pkg_name:
            search_names.append(f"org.{pkg_name}.{pkg_name}")

        for name in search_names:
            icon_info = icon_theme.choose_icon([name], size, 0)
            if icon_info:
                try:
                    pixbuf = icon_info.load_icon()
                    return pixbuf.scale_simple(size, size, GdkPixbuf.InterpType.BILINEAR)
                except Exception:
                    pass

        pixmaps_dir = '/usr/share/pixmaps'
        if os.path.isdir(pixmaps_dir):
            for ext in ('.png', '.svg', '.xpm'):
                path = os.path.join(pixmaps_dir, pkg_name + ext)
                if os.path.isfile(path):
                    try:
                        pixbuf = GdkPixbuf.Pixbuf.new_from_file(path)
                        return pixbuf.scale_simple(size, size, GdkPixbuf.InterpType.BILINEAR)
                    except Exception:
                        pass

        hicolor_base = '/usr/share/icons/hicolor'
        for subdir in ('48x48', '64x64', '128x128', '256x256'):
            apps_dir = os.path.join(hicolor_base, subdir, 'apps')
            if os.path.isdir(apps_dir):
                for ext in ('.png', '.svg'):
                    path = os.path.join(apps_dir, pkg_name + ext)
                    if os.path.isfile(path):
                        try:
                            pixbuf = GdkPixbuf.Pixbuf.new_from_file(path)
                            return pixbuf.scale_simple(size, size, GdkPixbuf.InterpType.BILINEAR)
                        except Exception:
                            pass

        papirus_base = '/usr/share/icons/Papirus'
        if os.path.isdir(papirus_base):
            for subdir in ('48x48', '64x64', '128x128', '256x256'):
                apps_dir = os.path.join(papirus_base, subdir, 'apps')
                if os.path.isdir(apps_dir):
                    for ext in ('.png', '.svg'):
                        path = os.path.join(apps_dir, pkg_name + ext)
                        if os.path.isfile(path):
                            try:
                                pixbuf = GdkPixbuf.Pixbuf.new_from_file(path)
                                return pixbuf.scale_simple(size, size, GdkPixbuf.InterpType.BILINEAR)
                            except Exception:
                                pass
        return None

    def update_package_info(self, pkg_name: str, pkg_version: str, pkg_desc: str):
        self.label_name.set_markup(f"<b>{pkg_name} {pkg_version}</b>")
        with self.lock:
            is_installed = pkg_name in self.installed_packages
        if is_installed:
            self.label_status.set_markup('<span class="status-installed">{}</span>'.format(_("✓ Установлен")))
            self.btn_install.set_sensitive(False)
            self.btn_remove.set_sensitive(True)
        else:
            self.label_status.set_markup('<span class="status-not-installed">{}</span>'.format(_("✗ Не установлен")))
            self.btn_install.set_sensitive(True)
            self.btn_remove.set_sensitive(False)
        self.label_desc.set_text(pkg_desc)

        pixbuf = self._find_app_icon(pkg_name, 64)
        if pixbuf:
            self.package_icon.set_from_pixbuf(pixbuf)
        else:
            self.package_icon.set_from_icon_name("package-x-generic", Gtk.IconSize.DIALOG)
            self.package_icon.set_pixel_size(64)

    def refresh_current_view(self):
        if self.current_category is None and not self.last_search_query:
            self.load_installed()
        elif self.last_search_query:
            self.run_in_thread(
                self.backend.search, self.on_search_complete,
                self.last_search_query, with_cancel=False
            )
        else:
            self.run_in_thread(
                self.backend.search, self.on_search_complete,
                self.current_category, with_cancel=False
            )

    def refresh_installed_set(self, callback_after=None):
        def target():
            return self.backend.list_installed()
        def on_done(result):
            self.spinner.stop()
            self.btn_cancel.set_sensitive(False)
            self.set_progress(0.0, _("Готов"))
            if isinstance(result, Exception):
                self.log_message(_("Ошибка обновления списка: {}").format(result))
                self.show_error_dialog(str(result))
            else:
                with self.lock:
                    self.installed_packages = {pkg['name'] for pkg in result}
                self.log_message(_("Список установленных пакетов обновлён."))
                if callback_after:
                    callback_after()
        self.run_in_thread(target, on_done, with_cancel=False)

    def on_sync_installed(self, button):
        self.log_message(_("Принудительное обновление списка установленных пакетов..."))
        def after_sync():
            self.refresh_current_view()
            selection = self.treeview.get_selection()
            model, treeiter = selection.get_selected()
            if treeiter:
                cur_name = model[treeiter][0]
                cur_ver = model[treeiter][1]
                cur_desc = model[treeiter][2]
                self.update_package_info(cur_name, cur_ver, cur_desc)
        self.refresh_installed_set(callback_after=after_sync)

    def on_category_selected(self, listbox, row):
        if row is None:
            return
        query = getattr(row, 'query', None)
        if self.current_category == query:
            return
        if self.current_thread and self.current_thread.is_alive():
            self.cancel_event.set()
        self.current_category = query
        self.search_entry.set_text("")
        if query is None:
            self.log_message(_("Загрузка установленных пакетов..."))
            self.run_in_thread(self.backend.list_installed, self.on_installed_loaded_callback, with_cancel=False)
        else:
            self.log_message(_("Категория: {} (запрос: {})").format(
                row.label_widget.get_text(), query))
            self.run_in_thread(self.backend.search, self.on_search_complete, query, with_cancel=False)

    def on_search(self, widget):
        query = self.search_entry.get_text().strip()
        if query == self.last_search_query:
            return
        self.last_search_query = query
        self.category_listbox.unselect_all()
        self.current_category = None
        if not query:
            self.load_installed()
            self.category_listbox.select_row(self.category_rows[0])
            return
        self.log_message(_("Поиск: {}").format(query))
        self.run_in_thread(self.backend.search, self.on_search_complete, query, with_cancel=False)

    def on_search_complete(self, result):
        self.spinner.stop()
        self.btn_cancel.set_sensitive(False)
        if isinstance(result, Exception):
            self.log_message(_("Ошибка: {}").format(result))
            self.show_error_dialog(str(result))
            self.set_progress(0.0, _("Ошибка"))
        else:
            self.populate_store(result)
            self.log_message(_("Найдено пакетов: {}").format(len(result)))

    def load_installed(self):
        self.run_in_thread(self.backend.list_installed, self.on_installed_loaded_callback, with_cancel=False)

    def on_installed_loaded_callback(self, result):
        self.spinner.stop()
        self.btn_cancel.set_sensitive(False)
        if isinstance(result, Exception):
            self.log_message(_("Ошибка загрузки: {}").format(result))
            self.show_error_dialog(str(result))
            self.set_progress(0.0, _("Ошибка"))
        else:
            with self.lock:
                self.installed_packages = {pkg['name'] for pkg in result}
            filtered = self.backend.filter_user_installed(result)
            self.populate_store(filtered)

            if self.last_installed_pkg:
                GLib.idle_add(self._select_package_in_store, self.last_installed_pkg)
                self.last_installed_pkg = None

            self.log_message(_("Загружено установленных пакетов: {} (показано {})").format(len(result), len(filtered)))

    def _select_package_in_store(self, pkg_name):
        model = self.treeview.get_model()
        for row in model:
            if row[0] == pkg_name:
                selection = self.treeview.get_selection()
                selection.select_iter(row.iter)
                path = model.get_path(row.iter)
                self.treeview.scroll_to_cell(path, None, True, 0.5, 0.5)
                self.on_selection_changed(self.treeview)
                break
        return False

    def on_selection_changed(self, treeview):
        selection = treeview.get_selection()
        model, treeiter = selection.get_selected()
        if treeiter is None:
            return
        pkg_name = model[treeiter][0]
        pkg_version = model[treeiter][1]
        pkg_desc = model[treeiter][2]
        self.update_package_info(pkg_name, pkg_version, pkg_desc)

    def on_install(self, button):
        selection = self.treeview.get_selection()
        model, treeiter = selection.get_selected()
        if treeiter is None:
            return
        pkg_name = model[treeiter][0]
        self.last_installed_pkg = pkg_name
        self.log_message(_("Установка: {}").format(pkg_name))
        self.run_in_thread(
            lambda: self.backend.install(pkg_name, cancel_event=self.cancel_event),
            self.on_action_complete
        )

    def on_remove(self, button):
        selection = self.treeview.get_selection()
        model, treeiter = selection.get_selected()
        if treeiter is None:
            return
        pkg_name = model[treeiter][0]
        self.log_message(_("Удаление: {}").format(pkg_name))
        self.pending_remove_pkg = pkg_name
        self.run_in_thread(
            lambda: self.backend.remove(pkg_name, cancel_event=self.cancel_event),
            self.on_action_complete
        )

    def on_action_complete(self, result):
        self.spinner.stop()
        self.btn_cancel.set_sensitive(False)
        if isinstance(result, Exception):
            err_msg = str(result)
            if isinstance(result, subprocess.CalledProcessError) and result.output:
                err_msg = result.output.strip()
            self.log_message(_("Ошибка операции: {}").format(err_msg))
            self.show_error_dialog(_("Ошибка: {}").format(err_msg))
            self.set_progress(0.0, _("Ошибка"))
        else:
            self.log_message(_("Операция успешно завершена."))
            self.set_progress(1.0, _("Готов"))

            if self.pending_remove_pkg:
                with self.lock:
                    self.installed_packages.discard(self.pending_remove_pkg)
                selection = self.treeview.get_selection()
                model, treeiter = selection.get_selected()
                if treeiter:
                    cur_name = model[treeiter][0]
                    if cur_name == self.pending_remove_pkg:
                        cur_ver = model[treeiter][1]
                        cur_desc = model[treeiter][2]
                        self.update_package_info(cur_name, cur_ver, cur_desc)
                self.pending_remove_pkg = None

            if self.last_installed_pkg:
                self.category_listbox.select_row(self.category_rows[0])
                self.search_entry.set_text("")
                self.last_search_query = ""
                self.current_category = None
                self.refresh_installed_set(callback_after=None)
            else:
                def after_refresh():
                    self.refresh_current_view()
                    selection = self.treeview.get_selection()
                    model, treeiter = selection.get_selected()
                    if treeiter:
                        cur_name = model[treeiter][0]
                        cur_ver = model[treeiter][1]
                        cur_desc = model[treeiter][2]
                        self.update_package_info(cur_name, cur_ver, cur_desc)
                self.refresh_installed_set(callback_after=after_refresh)

    def on_refresh_cache(self, button):
        self.log_message(_("Обновление кэша пакетов..."))
        self.run_in_thread(
            lambda: self.backend.refresh_cache(cancel_event=self.cancel_event),
            self.on_action_complete
        )

    def on_system_upgrade(self, button):
        self.log_message(_("Полное обновление системы..."))
        self.run_in_thread(
            lambda: self.backend.system_upgrade(cancel_event=self.cancel_event),
            self.on_action_complete
        )

    def on_language_changed(self, combo):
        new_lang = 'ru' if combo.get_active() == 0 else 'en'
        if i18n.current_lang == new_lang:
            return
        i18n.current_lang = new_lang
        self.switch_language()

    def switch_language(self):
        self.set_title("XfMarket (версия 0.1.4)")
        self.search_entry.set_placeholder_text(_("Поиск пакетов..."))
        self.btn_refresh_cache.set_label(_("Обновить кэш"))
        self.btn_sync.set_label(_("Обновить список ПО"))
        self.btn_sync.set_tooltip_text(_("Заново загрузить список установленных пакетов"))
        self.btn_upgrade.set_label(_("Обновить всё"))
        self.btn_cancel.set_label(_("Отмена"))
        self.progress_bar.set_text(_("Готов"))
        self.lbl_categories.set_markup("<b>{}</b>".format(_("Категории")))

        for row in self.category_rows:
            row.label_widget.set_text(_(row.name_key))

        self.treeview.get_column(0).set_title(_("Пакет"))
        self.treeview.get_column(1).set_title(_("Версия"))
        self.label_name.set_text(_("Выберите пакет"))
        self.btn_install.set_label(_("Установить"))
        self.btn_remove.set_label(_("Удалить"))
        self.lang_label.set_text("Язык:" if i18n.current_lang == 'ru' else "Language:")

        selection = self.treeview.get_selection()
        model, treeiter = selection.get_selected()
        if treeiter:
            cur_name = model[treeiter][0]
            cur_ver = model[treeiter][1]
            cur_desc = model[treeiter][2]
            self.update_package_info(cur_name, cur_ver, cur_desc)
        else:
            self.label_status.set_text("")
            self.btn_install.set_sensitive(False)
            self.btn_remove.set_sensitive(False)

if __name__ == "__main__":
    win = PackageManagerGUI()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()
