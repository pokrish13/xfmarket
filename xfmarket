def detect_distro() -> Optional[str]:
    try:
        import distro
        dist_id = distro.id()
        if dist_id in ('debian', 'ubuntu', 'linuxmint', 'pop', 'raspbian'):
            return 'debian'
        if dist_id == 'arch':
            return 'arch'
        if dist_id in ('opensuse', 'suse', 'opensuse-leap', 'opensuse-tumbleweed'):
            return 'opensuse'
        if dist_id == 'void':
            return 'void'
        if dist_id == 'gentoo':
            return 'gentoo'
        if dist_id == 'fedora':
            return 'fedora'
    except ImportError:
        pass

    if os.path.isfile('/etc/debian_version'):
        return 'debian'
    if os.path.isfile('/etc/arch-release'):
        return 'arch'
    if os.path.isfile('/etc/SuSE-release') or os.path.isfile('/etc/suse-release'):
        return 'opensuse'
    if os.path.isfile('/etc/void-release'):
        return 'void'
    if os.path.isfile('/etc/gentoo-release'):
        return 'gentoo'
    if os.path.isfile('/etc/fedora-release'):
        return 'fedora'

    try:
        with open('/etc/os-release') as f:
            content = f.read().lower()
            if 'debian' in content or 'ubuntu' in content:
                return 'debian'
            if 'arch' in content:
                return 'arch'
            if 'opensuse' in content or 'suse' in content:
                return 'opensuse'
            if 'void' in content:
                return 'void'
            if 'gentoo' in content:
                return 'gentoo'
            if 'fedora' in content:
                return 'fedora'
    except Exception:
        pass

    for cmd, dist in [('apt', 'debian'), ('pacman', 'arch'), ('zypper', 'opensuse'),
                      ('xbps-install', 'void'), ('emerge', 'gentoo'), ('dnf', 'fedora')]:
        if shutil.which(cmd):
            return dist
    return None

def detect_priv_exec() -> str:
    for cmd in ['pkexec', 'sudo', 'doas']:
        if shutil.which(cmd):
            return cmd
    raise RuntimeError("No privilege escalation tool found (pkexec, sudo, doas)")

PRIV_EXEC = detect_priv_exec()

class CancellableProcess:
    def __init__(self, cmd: List[str], timeout: int = 600):
        self.cmd = cmd
        self.timeout = timeout
        self.proc = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            env={**os.environ, 'LANG': 'C', 'LC_ALL': 'C'}
        )
        self.output_lines: List[str] = []
        self.cancelled = False

    def communicate(self, cancel_event: Optional[threading.Event] = None,
                    log_callback: Optional[Callable[[str], None]] = None) -> tuple:
        start_time = time.time()
        for line in iter(self.proc.stdout.readline, ''):
            if cancel_event and cancel_event.is_set():
                self._terminate()
                self.cancelled = True
                break
            self.output_lines.append(line)
            if log_callback:
                log_callback(line.rstrip())
            if time.time() - start_time > self.timeout:
                self.proc.kill()
                raise subprocess.TimeoutExpired(self.cmd, self.timeout)
        if not self.cancelled:
            self.proc.wait()
        return self.proc.returncode, ''.join(self.output_lines)

    def _terminate(self):
        self.proc.terminate()
        try:
            self.proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            self.proc.kill()
            self.proc.wait()

def run_command_async(cmd: List[str],
                      cancel_event: Optional[threading.Event] = None,
                      timeout: int = 600,
                      log_callback: Optional[Callable[[str], None]] = None,
                      progress_callback: Optional[Callable[[int, int], None]] = None) -> tuple:
    proc = CancellableProcess(cmd, timeout)
    ret, out = proc.communicate(cancel_event, log_callback)
    if progress_callback and not proc.cancelled:
        progress_callback(len(proc.output_lines), 0)
    if proc.cancelled:
        raise RuntimeError("Operation cancelled by user")
    if ret != 0:
        raise subprocess.CalledProcessError(ret, cmd, output=out, stderr=out)
    return ret, out

class PackageBackend:
    CACHE_TIMEOUT = 600
    INSTALL_TIMEOUT = 1200
    UPGRADE_TIMEOUT = 3600

    def search(self, query: str, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        raise NotImplementedError

    def list_installed(self, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        raise NotImplementedError

    def install(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        raise NotImplementedError

    def remove(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        raise NotImplementedError

    def refresh_cache(self, cancel_event: Optional[threading.Event] = None) -> None:
        raise NotImplementedError

    def system_upgrade(self, cancel_event: Optional[threading.Event] = None) -> None:
        raise NotImplementedError

    def check_prerequisites(self) -> None:
        pass

    def filter_user_installed(self, packages: List[Dict[str, str]]) -> List[Dict[str, str]]:
        return packages

class DebianBackend(PackageBackend):
    REQUIRED_CMDS = ['apt-cache', 'dpkg-query', 'apt']

    def check_prerequisites(self) -> None:
        for cmd in self.REQUIRED_CMDS:
            if not shutil.which(cmd):
                raise RuntimeError(f"Required command not found: {cmd}")

    def search(self, query: str, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['apt-cache', 'search', query])
        pkgs = []
        for line in out.splitlines():
            if ' - ' in line:
                name, desc = line.split(' - ', 1)
                pkgs.append({'name': name.strip(), 'version': '', 'description': desc.strip()})
        return pkgs

    def list_installed(self, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['dpkg-query', '-W', '-f=${Package} ${Version} ${Description}\n'])
        pkgs = []
        for line in out.splitlines():
            parts = line.split(' ', 2)
            if len(parts) >= 2:
                pkgs.append({'name': parts[0], 'version': parts[1],
                             'description': parts[2] if len(parts) > 2 else ''})
        return pkgs

    def install(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'apt', 'install', '-y', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def remove(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'apt', 'remove', '-y', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def refresh_cache(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'apt', 'update'], cancel_event=cancel_event, timeout=self.CACHE_TIMEOUT)

    def system_upgrade(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'apt', 'full-upgrade', '-y'], cancel_event=cancel_event, timeout=self.UPGRADE_TIMEOUT)

    def filter_user_installed(self, packages: List[Dict[str, str]]) -> List[Dict[str, str]]:
        try:
            _, out = run_command_async(['apt-mark', 'showmanual'])
            manual_names = set(out.splitlines())
            return [pkg for pkg in packages if pkg['name'] in manual_names]
        except Exception:
            return packages

class ArchBackend(PackageBackend):
    REQUIRED_CMDS = ['pacman']

    def check_prerequisites(self) -> None:
        if not shutil.which('pacman'):
            raise RuntimeError("Required command not found: pacman")

    def search(self, query: str, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['pacman', '-Ss', query])
        pkgs = []
        pattern = re.compile(r'^(\S+)/(\S+)\s+(.*?)\s*$')
        current_pkg = None
        for line in out.splitlines():
            if not line.startswith(' '):
                match = pattern.match(line)
                if match:
                    if current_pkg:
                        pkgs.append(current_pkg)
                    current_pkg = {
                        'name': match.group(2),
                        'version': match.group(3) if match.group(3) else '',
                        'description': ''
                    }
                else:
                    current_pkg = None
            else:
                if current_pkg is not None:
                    current_pkg['description'] += line.strip() + ' '
        if current_pkg:
            pkgs.append(current_pkg)
        return pkgs

    def list_installed(self, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['pacman', '-Q'])
        pkgs = []
        for line in out.splitlines():
            parts = line.split(' ')
            if len(parts) >= 2:
                pkgs.append({'name': parts[0], 'version': parts[1], 'description': ''})
        return pkgs

    def install(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'pacman', '-S', '--noconfirm', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def remove(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'pacman', '-R', '--noconfirm', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def refresh_cache(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'pacman', '-Sy'], cancel_event=cancel_event, timeout=self.CACHE_TIMEOUT)

    def system_upgrade(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'pacman', '-Syu', '--noconfirm'], cancel_event=cancel_event, timeout=self.UPGRADE_TIMEOUT)

    def filter_user_installed(self, packages: List[Dict[str, str]]) -> List[Dict[str, str]]:
        try:
            _, out = run_command_async(['pacman', '-Qqe'])
            explicit_names = set(out.splitlines())
            return [pkg for pkg in packages if pkg['name'] in explicit_names]
        except Exception:
            return packages

class OpensuseBackend(PackageBackend):
    REQUIRED_CMDS = ['zypper']

    def check_prerequisites(self) -> None:
        if not shutil.which('zypper'):
            raise RuntimeError("Required command not found: zypper")

    def _parse_zypper_table(self, out: str) -> List[Dict[str, str]]:
        pkgs = []
        lines = out.splitlines()
        header_idx = -1
        for i, line in enumerate(lines):
            if 'S ' in line and '|' in line and 'Name' in line:
                header_idx = i
                break
        if header_idx == -1:
            return pkgs
        header = lines[header_idx]
        col_positions = [pos for pos, char in enumerate(header) if char == '|']
        if len(col_positions) < 2:
            return pkgs
        for line in lines[header_idx+1:]:
            if not line.strip():
                continue
            if '|' not in line:
                continue
            parts = []
            prev = 0
            for pos in col_positions[1:]:
                parts.append(line[prev+1:pos].strip())
                prev = pos
            parts.append(line[prev+1:].strip())
            if len(parts) >= 2:
                pkgs.append({
                    'name': parts[1] if len(parts) > 1 else '',
                    'version': parts[2] if len(parts) > 2 else '',
                    'description': parts[-1] if len(parts) > 2 else ''
                })
        return pkgs

    def search(self, query: str, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['zypper', '--no-color', 'search', query])
        return self._parse_zypper_table(out)

    def list_installed(self, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['zypper', '--no-color', 'search', '-i'])
        return self._parse_zypper_table(out)

    def install(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'zypper', 'install', '-y', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def remove(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'zypper', 'remove', '-y', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def refresh_cache(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'zypper', 'refresh'], cancel_event=cancel_event, timeout=self.CACHE_TIMEOUT)

    def system_upgrade(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'zypper', 'update', '-y'], cancel_event=cancel_event, timeout=self.UPGRADE_TIMEOUT)

class VoidBackend(PackageBackend):
    REQUIRED_CMDS = ['xbps-query', 'xbps-install', 'xbps-remove']

    def check_prerequisites(self) -> None:
        for cmd in self.REQUIRED_CMDS:
            if not shutil.which(cmd):
                raise RuntimeError(f"Required command not found: {cmd}")

    def search(self, query: str, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['xbps-query', '-Rs', query])
        pkgs = []
        pattern = re.compile(r'^\[\w+\]\s+(\S+)\s+(.*)$')
        for line in out.splitlines():
            match = pattern.match(line)
            if match:
                full_name = match.group(1)
                desc = match.group(2)
                last_dash = full_name.rfind('-')
                if last_dash != -1 and re.match(r'\d', full_name[last_dash+1:]):
                    name = full_name[:last_dash]
                    version = full_name[last_dash+1:]
                else:
                    name = full_name
                    version = ''
                pkgs.append({'name': name, 'version': version, 'description': desc})
        return pkgs

    def list_installed(self, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['xbps-query', '-l'])
        pkgs = []
        for line in out.splitlines():
            if line.startswith('ii '):
                parts = line.split()[1:]
                if parts:
                    pkg_str = parts[0]
                    last_dash = pkg_str.rfind('-')
                    if last_dash != -1 and re.match(r'\d', pkg_str[last_dash+1:]):
                        name = pkg_str[:last_dash]
                        version = pkg_str[last_dash+1:]
                    else:
                        name = pkg_str
                        version = ''
                    pkgs.append({'name': name, 'version': version, 'description': ''})
        return pkgs

    def install(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'xbps-install', '-y', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def remove(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'xbps-remove', '-y', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def refresh_cache(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'xbps-install', '-S'], cancel_event=cancel_event, timeout=self.CACHE_TIMEOUT)

    def system_upgrade(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'xbps-install', '-Su', '-y'], cancel_event=cancel_event, timeout=self.UPGRADE_TIMEOUT)

class GentooBackend(PackageBackend):
    REQUIRED_CMDS = ['emerge', 'qlist']

    def check_prerequisites(self) -> None:
        for cmd in self.REQUIRED_CMDS:
            if not shutil.which(cmd):
                raise RuntimeError(f"Required command not found: {cmd}")

    def search(self, query: str, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['emerge', '--search', query])
        pkgs = []
        pattern_name = re.compile(r'^\*\s+(\S+)')
        pattern_desc = re.compile(r'^\s*Description:\s*(.*)')
        current_name = ''
        current_desc = ''
        for line in out.splitlines():
            name_match = pattern_name.match(line)
            if name_match:
                if current_name:
                    pkgs.append({'name': current_name, 'version': '', 'description': current_desc})
                current_name = name_match.group(1)
                current_desc = ''
            desc_match = pattern_desc.match(line)
            if desc_match:
                current_desc = desc_match.group(1).strip()
        if current_name:
            pkgs.append({'name': current_name, 'version': '', 'description': current_desc})
        return pkgs

    def list_installed(self, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['qlist', '-Iv'])
        pkgs = []
        for line in out.splitlines():
            parts = line.split('/')
            if len(parts) >= 2:
                pkg = parts[1]
                name_version = pkg.rsplit('-', 1)
                pkgs.append({'name': name_version[0],
                             'version': name_version[1] if len(name_version) > 1 else '',
                             'description': ''})
        return pkgs

    def install(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'emerge', '--ask=n', '--pretend', pkg_name])
        run_command_async([PRIV_EXEC, 'emerge', '--ask=n', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def remove(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'emerge', '--ask=n', '--depclean', '--pretend', pkg_name])
        run_command_async([PRIV_EXEC, 'emerge', '--ask=n', '-C', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def refresh_cache(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'emerge', '--sync'], cancel_event=cancel_event, timeout=self.CACHE_TIMEOUT)

    def system_upgrade(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'emerge', '--ask=n', '-uDN', '@world'], cancel_event=cancel_event, timeout=self.UPGRADE_TIMEOUT)

class FedoraBackend(PackageBackend):
    REQUIRED_CMDS = ['dnf']

    def check_prerequisites(self) -> None:
        if not shutil.which('dnf'):
            raise RuntimeError("Required command not found: dnf")

    def search(self, query: str, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['dnf', 'search', query])
        pkgs = []
        for line in out.splitlines():
            if ' : ' in line:
                name_ver, desc = line.split(' : ', 1)
                pkgs.append({'name': name_ver.strip(), 'version': '', 'description': desc.strip()})
        return pkgs

    def list_installed(self, cancel_event: Optional[threading.Event] = None) -> List[Dict[str, str]]:
        _, out = run_command_async(['dnf', 'list', 'installed'])
        pkgs = []
        for line in out.splitlines():
            if line and not line.startswith('Installed'):
                parts = line.split()
                if len(parts) >= 2:
                    name_arch = parts[0].rsplit('.', 1)
                    if len(name_arch) == 2 and name_arch[1] in ('x86_64', 'i686', 'noarch', 'aarch64'):
                        name = name_arch[0]
                    else:
                        name = parts[0]
                    version = parts[1]
                    pkgs.append({'name': name, 'version': version, 'description': ''})
        return pkgs

    def install(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'dnf', 'install', '-y', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def remove(self, pkg_name: str, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'dnf', 'remove', '-y', pkg_name], cancel_event=cancel_event, timeout=self.INSTALL_TIMEOUT)

    def refresh_cache(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'dnf', 'makecache'], cancel_event=cancel_event, timeout=self.CACHE_TIMEOUT)

    def system_upgrade(self, cancel_event: Optional[threading.Event] = None) -> None:
        run_command_async([PRIV_EXEC, 'dnf', 'upgrade', '-y'], cancel_event=cancel_event, timeout=self.UPGRADE_TIMEOUT)

