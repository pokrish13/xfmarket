    def _set_progress_idle(self, fraction: float, text: Optional[str]):
        self.progress_bar.set_fraction(fraction)
        if text:
            self.progress_bar.set_text(text)
        return False

    def run_in_thread(self, target, callback=None, *args, with_cancel=True):
        if self.current_thread and self.current_thread.is_alive():
            self.cancel_event.set()
        self.cancel_event.clear()
        self.btn_cancel.set_sensitive(True)
        self.spinner.start()
        self.set_progress(0.0, _("Выполнение..."))

        def wrapper():
            try:
                result = target(*args)
            except Exception as e:
                result = e
            if not self.cancel_event.is_set() and callback:
                GLib.idle_add(callback, result)
            else:
                GLib.idle_add(self.on_cancelled_complete)
            self.current_thread = None

        self.current_thread = threading.Thread(target=wrapper)
        self.current_thread.daemon = True
        self.current_thread.start()

    def on_cancelled_complete(self):
        self.spinner.stop()
        self.btn_cancel.set_sensitive(False)
        self.set_progress(0.0, _("Отменено"))
        self.log_message(_("Операция отменена."))

    def on_cancel(self, button):
        self.cancel_event.set()
        self.log_message(_("Отправлен запрос на отмену..."))
        self.spinner.stop()
        self.btn_cancel.set_sensitive(False)
        self.set_progress(0.0, _("Отмена..."))

